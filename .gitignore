# ─────────────────────────────────────────────────────────────────────────────
# Monorepo root .gitignore
# Applies to both client/ and server/ unless overridden by a nested .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ---------- Dependencies ----------
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ---------- Build outputs ----------
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.turbo/
*.tsbuildinfo
.tsbuildinfo

# ---------- TypeScript / tsc caches ----------
**/node_modules/.cache/
**/.cache/tsc/
**/*.tsbuildinfo

# ---------- Env & secrets ----------
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.cert
credentials.json
secrets.json

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Runtime / process ----------
pids/
*.pid
*.seed
*.pid.lock

# ---------- Coverage / test artifacts ----------
coverage/
*.lcov
.nyc_output/
junit.xml
playwright-report/
test-results/

# ---------- Editor / IDE ----------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
.fleet/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ---------- OS junk ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- Vite / Vitest ----------
*.local
.vite/
vite.config.*.timestamp-*

# ---------- Misc ----------
.history/
.tmp/
.temp/
tmp/
temp/
