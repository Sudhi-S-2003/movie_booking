# ── Docker Compose Environment ────────────────────────────────────────────────
# Copy this file to .env and adjust values for your deployment.

# Application
NODE_ENV=production
PORT=5000
CLIENT_PORT=80

# MongoDB (used by server + worker)
MONGODB_URI=mongodb://mongo:27017/cinema-connect

# Redis (used by server queue + worker)
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=change_me_to_a_strong_random_string
JWT_EXPIRES_IN=1d

# Frontend URL (for CORS origin)
FRONTEND_URL=http://localhost
